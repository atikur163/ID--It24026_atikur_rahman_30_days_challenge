
class Car {
    String brand;
    int year;
    void displayInfo() {
        System.out.println("Brand: " + brand + ", Year: " + year);
    }
}
public class Main {
    public static void main(String[] args) {
        Car myCar = new Car();
        myCar.brand = "Runner";
        myCar.year = 2026;
        myCar.displayInfo(); 
    }
}
